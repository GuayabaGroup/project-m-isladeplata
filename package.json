{
  "name": "project-m-isladeplata",
  "version": "0.0.0",
  "description": "Isladeplata — agente conversacional de atención al cliente con LangGraph + TypeScript",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "tsx watch src/main/server.ts",
    "build": "tsc",
    "start": "node --enable-source-maps dist/main/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src tests",
    "lint:fix": "biome check --write src tests",
    "format": "biome format --write src tests"
  },
  "author": "GuayabaGroup",
  "license": "UNLICENSED",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.99.0",
    "@langchain/core": "^1.1.0",
    "@langchain/langgraph": "^1.3.0",
    "@langchain/langgraph-checkpoint-postgres": "^1.0.0",
    "@sentry/node": "^9.0.0",
    "axios": "^1.15.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.0",
    "express": "^5.0.0",
    "helmet": "^8.0.0",
    "langsmith": "^0.3.0",
    "openai": "^6.39.0",
    "pg": "^8.13.0",
    "prom-client": "^15.1.3",
    "redis": "^4.7.0",
    "uuid": "^11.0.0",
    "winston": "^3.19.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/cors": "^2.8.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.19.0",
    "@types/pg": "^8.11.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.0",
    "vitest": "^2.1.9"
  }
}
