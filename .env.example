# Entorno
NODE_ENV=development
LOG_LEVEL=info

# Observability — Sentry (errores no esperados, excepciones)
SENTRY_DSN=

# Observability — LangSmith (tracing del grafo, runs LLM, tool calls)
# Si LANGSMITH_TRACING=true, se requiere LANGSMITH_API_KEY no vacío.
# En producción se recomienda HIDE_INPUTS/HIDE_OUTPUTS=true para no enviar
# PII al servicio externo (ver §13 REGLAS_ISLADEPLATA).
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=isladeplata-dev
LANGSMITH_ENDPOINT=
LANGSMITH_HIDE_INPUTS=false
LANGSMITH_HIDE_OUTPUTS=false

# Guacuco — backend de turnos/identidad/operaciones
GUACUCO_URL=http://localhost:4001
GUACUCO_API_KEY=
GUACUCO_TIMEOUT_MS=10000

# Parguito — CRM (stub Etapa 3, retorna defaults si falla)
PARGUITO_URL=http://localhost:4002
PARGUITO_API_KEY=
PARGUITO_TIMEOUT_MS=10000

# HTTP server
PORT=4000

# Redis (dedup + rate limit; sesiones van al checkpointer Postgres en H3)
REDIS_URL=redis://localhost:6379
DEDUP_TTL_SECONDS=300
RATE_LIMIT_MAX_PER_MINUTE=20

# WhatsApp Cloud API
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_GRAPH_API_VERSION=v22.0
# JSON mapping: phone_number_id → { access_token, role, platform_id }
# Ej: '{"123456":{"access_token":"EAAG...","role":"staff","platform_id":1}}'
WHATSAPP_CHANNEL_MAP_JSON={}
# JSON mapping: platform_id (string) → app_secret
# Ej: '{"1":"abc...","2":"def...","3":"ghi..."}'
APP_SECRET_BY_PLATFORM_JSON={}

# Postgres del agente (checkpointer LangGraph). Conceptualmente distinto al
# Postgres del negocio (que vive en Guacuco y NO se accede directo).
POSTGRES_URL=postgres://user:password@localhost:5432/isladeplata
# TTL del checkpoint: tras este lapso de inactividad se considera expirado al lookup.
CHECKPOINTER_TTL_SECONDS=86400
# Frecuencia del job de cleanup periódico que borra checkpoints viejos.
CHECKPOINTER_CLEANUP_INTERVAL_SECONDS=3600
