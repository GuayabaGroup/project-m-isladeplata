# Entorno
NODE_ENV=development
LOG_LEVEL=info

# Observability — Sentry (errores no esperados, excepciones)
SENTRY_DSN=

# Observability — LangSmith (tracing del grafo, runs LLM, tool calls)
# Si LANGSMITH_TRACING=true, se requiere LANGSMITH_API_KEY no vacío.
# En producción se recomienda HIDE_INPUTS/HIDE_OUTPUTS=true para no enviar
# PII al servicio externo (ver §13 REGLAS_ISLADEPLATA).
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=isladeplata-dev
LANGSMITH_ENDPOINT=
LANGSMITH_HIDE_INPUTS=false
LANGSMITH_HIDE_OUTPUTS=false
