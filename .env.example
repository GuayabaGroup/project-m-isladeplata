# Isladeplata — plantilla de variables de entorno.
# Copiar a `.env` y completar. `src/config/env.ts` valida con Zod al boot
# (fail-fast). Las vars con default pueden omitirse.

# --- Runtime ---
NODE_ENV=development              # development | test | production
LOG_LEVEL=info                    # debug | info | warn | error | silent
PORT=4000

# --- Observability ---
SENTRY_DSN=

# LangSmith (tracing del grafo + LLM). En producción: HIDE_INPUTS/OUTPUTS=true
# y un proyecto separado por entorno (isladeplata-prod).
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=isladeplata-dev
# LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com   # opcional (EU/self-hosted)
LANGSMITH_HIDE_INPUTS=false
LANGSMITH_HIDE_OUTPUTS=false

# --- Backends propios (HTTP, sin Postgres directo del negocio) ---
GUACUCO_URL=http://localhost:4001
GUACUCO_API_KEY=changeme
GUACUCO_TIMEOUT_MS=10000

# Parguito (CRM). Mientras ENABLED=false el pre-grafo no consulta el endpoint y
# pasa CRM vacío al grafo (los turnos próximos vienen igual de Guacuco).
PARGUITO_URL=http://localhost:4002
PARGUITO_API_KEY=changeme
PARGUITO_TIMEOUT_MS=10000
PARGUITO_ENABLED=false

# --- Redis (dedup + rate limit únicamente) ---
REDIS_URL=redis://localhost:6379
DEDUP_TTL_SECONDS=300
RATE_LIMIT_MAX_PER_MINUTE=20

# --- WhatsApp Cloud API ---
WHATSAPP_VERIFY_TOKEN=changeme
WHATSAPP_GRAPH_API_VERSION=v22.0
# JSON: { "<phone_number_id>": { "access_token": "...", "role": "staff"|"client", "platform_id": 1 }, ... }
WHATSAPP_CHANNEL_MAP_JSON={}
# JSON: { "1": "<app_secret_allia>", "2": "<app_secret_groomia>", "3": "<app_secret_divapp>" }
APP_SECRET_BY_PLATFORM_JSON={}
# Dev-only: saltea HMAC del webhook. PROHIBIDO en producción (fail-fast en env.ts).
WHATSAPP_SKIP_SIGNATURE=false

# --- Postgres del agente (checkpointer LangGraph; NUNCA el del negocio) ---
POSTGRES_URL=postgres://user:pass@localhost:5432/isladeplata
CHECKPOINTER_TTL_SECONDS=86400          # 24h
CHECKPOINTER_CLEANUP_INTERVAL_SECONDS=3600

# --- LLM (provider-agnóstico) ---
LLM_PROVIDER=anthropic                  # anthropic | openai

# Anthropic (requerido si LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
SUPERVISOR_MODEL=claude-haiku-4-5-20251001
RESPONSE_MODEL=claude-haiku-4-5-20251001
QUERY_JUDGE_MODEL=claude-haiku-4-5-20251001

# OpenAI (requerido si LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_SUPERVISOR_MODEL=gpt-4o-mini
OPENAI_RESPONSE_MODEL=gpt-4o-mini
OPENAI_QUERY_JUDGE_MODEL=gpt-4o-mini

# QueryJudge (freeform_sql): valida SQL + síntesis contra los rows reales.
QUERY_JUDGE_ENABLED=true                # true | false
QUERY_JUDGE_FAIL_MODE=fail-open         # fail-open | fail-closed

# --- Métricas (/metrics). Vacío = endpoint no se monta. ---
METRICS_API_KEY=

# --- Outbound S2S (POST /api/v1/outbound/messages). ---
# API key que presenta Guacuco via header X-API-Key. Requerida, min 16 chars.
# DEBE coincidir con IDP_API_KEY en Guacuco.
IDP_API_KEY=
